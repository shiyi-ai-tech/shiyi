{
  "clerk_id": "clerk_default_001",
  "name": "默认吏员",
  "version": "0.1.0",
  "description": "提供文件读写和网页搜索的基础吏员",
  "capabilities": ["file_read", "file_write", "web_search"],
  "tools": [
    {
      "name": "file_read",
      "description": "读取文件内容或列出目录",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "文件路径（沙箱内，相对于 workspace 或绝对路径）"
          },
          "limit": {
            "type": "integer",
            "description": "最大读取行数（默认500）",
            "default": 500
          }
        },
        "required": ["path"]
      }
    },
    {
      "name": "file_write",
      "description": "写入内容到文件",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "文件路径（沙箱内，相对于 workspace 或绝对路径）"
          },
          "content": {
            "type": "string",
            "description": "要写入的内容"
          }
        },
        "required": ["path", "content"]
      }
    },
    {
      "name": "web_search",
      "description": "搜索互联网信息",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "搜索关键词"
          },
          "max_results": {
            "type": "integer",
            "description": "最大结果数（默认3）",
            "default": 3
          }
        },
        "required": ["query"]
      }
    }
  ],
  "enabled": true,
  "created_at": "2026-05-19",
  "config_path": "clerk-default/",
  "skills": ["file_ops", "web_search"],
  "api_keys": [],
  "requires_llm": false,
  "knowledge_base": "knowledge/"
}
